80|def _count_from_jsonl(path_glob: str) -> dict:
81|    """Read token data from JSONL usage logs."""
82|    import glob
83|    total_in = total_out = 0
84|    for f in sorted(glob.glob(os.path.expanduser(path_glob)), key=os.path.getmtime, reverse=True)[:5]:
85|        try:
86|            for line in open(f):
87|                d = json.loads(line)
88|                u = d.get("usage", {})
89|                total_in += u.get("input_tokens", u.get("prompt_tokens", 0))
90|                total_out += u.get("output_tokens", u.get("completion_tokens", 0))
91|        except Exception:
92|            continue
93|    return {"input": total_in, "output": total_out}
