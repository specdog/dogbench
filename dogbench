53|def count_tokens(agent_id: str) -> dict:
54|    """Estimate token count for the last run. Uses official logs where available."""
55|    if agent_id in ("collar", "hermes"):
56|        return _count_from_dag()
57|    elif agent_id == "claude":
58|        return _count_from_jsonl("~/Library/Application Support/Claude/usage/*.jsonl")
59|    elif agent_id == "codex":
60|        return _count_from_jsonl("~/.codex/usage/*.jsonl")
61|    return {"input": 0, "output": 0}
