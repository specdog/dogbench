64|def _count_from_dag() -> dict:
65|    """Read collar session tokens."""
66|    sessions = Path.home() / ".dag" / "sessions"
67|    total_in = total_out = 0
68|    for f in sorted(sessions.glob("*.jsonl"), key=os.path.getmtime, reverse=True)[:3]:
69|        try:
70|            for line in open(f):
71|                d = json.loads(line)
72|                u = d.get("usage", {})
73|                total_in += u.get("prompt_tokens", u.get("input_tokens", 0))
74|                total_out += u.get("completion_tokens", u.get("output_tokens", 0))
75|        except Exception:
76|            continue
77|    return {"input": total_in, "output": total_out}
