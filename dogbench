43|def detect_installed() -> list:
44|    """Return list of agent IDs that are actually installed."""
45|    available = []
46|    for aid, cfg in AGENTS.items():
47|        binary = cfg["cmd"].split()[0]
48|        if subprocess.run(["which", binary], capture_output=True).returncode == 0:
49|            available.append(aid)
50|    return available
