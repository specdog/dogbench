#!/usr/bin/env python3
"""dogbench — one command to prove collar saves tokens."""
import argparse, json, os, subprocess, sys, time
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
DEFAULT_TASK = "Write a Python script that reads CSV sales data, groups by category, calculates revenue, and writes unit tests. Use standard library only."

AGENTS = {
    "collar": {"name": "collar (DAG-first)", "cmd": 'collar chat -q "{prompt}"', "color": "\033[32m"},
    "claude": {"name": "Claude Code", "cmd": 'claude "{prompt}" --print', "color": "\033[34m"},
    "codex":  {"name": "OpenAI Codex", "cmd": 'codex exec "{prompt}"', "color": "\033[35m"},
}

RATES = {"gpt-5": {"input": 1.25, "output": 10.0}, "claude": {"input": 3.0, "output": 15.0}, "default": {"input": 1.0, "output": 5.0}}

def detect():
    return [a for a, c in AGENTS.items() if subprocess.run(["which", c["cmd"].split()[0]], capture_output=True).returncode == 0]

def count_tokens(agent_id):
    home = Path.home()
    if agent_id == "collar":
        total_in = total_out = 0
        sessions = home / ".dag" / "sessions"
        if sessions.is_dir():
            for f in sorted(sessions.glob("*.jsonl"), key=os.path.getmtime, reverse=True)[:3]:
                try:
                    for line in open(f):
                        d = json.loads(line)
                        u = d.get("usage", {})
                        total_in += u.get("prompt_tokens", u.get("input_tokens", 0))
                        total_out += u.get("completion_tokens", u.get("output_tokens", 0))
                except: continue
        return {"input": total_in, "output": total_out}
    elif agent_id == "claude":
        path = home / "Library" / "Application Support" / "Claude" / "usage"
    elif agent_id == "codex":
        path = home / ".codex" / "usage"
    else:
        return {"input": 0, "output": 0}
    total_in = total_out = 0
    if path.is_dir():
        for f in sorted(path.glob("*.jsonl"), key=os.path.getmtime, reverse=True)[:5]:
            try:
                for line in open(f):
                    d = json.loads(line)
                    u = d.get("usage", {})
                    total_in += u.get("input_tokens", u.get("prompt_tokens", 0))
                    total_out += u.get("output_tokens", u.get("completion_tokens", 0))
            except: continue
    return {"input": total_in, "output": total_out}

def fmt(n): return f"{n:,}" if n else "N/A"
def cost(i, o, m="default"):
    r = RATES.get(m, RATES["default"])
    return (i/1e6)*r["input"] + (o/1e6)*r["output"]

def main():
    p = argparse.ArgumentParser()
    p.add_argument("task", nargs="?", default=DEFAULT_TASK)
    p.add_argument("--model", default="gpt-5")
    p.add_argument("--compare", nargs="*", default=["claude", "codex"])
    p.add_argument("--all", action="store_true")
    p.add_argument("--json", action="store_true")
    p.add_argument("--dag", action="store_true")
    args = p.parse_args()

    available = detect()
    if "collar" not in available:
        print("collar not installed"); sys.exit(1)

    targets = ["collar"]
    if args.all:
        targets = [a for a in available if a != "collar"][:4]
        targets.insert(0, "collar")
    else:
        for a in args.compare:
            if a in available: targets.append(a)

    print(f"\n\033[1m  dogbench\033[0m  {len(targets)} agents  model={args.model}\n")

    results = {}
    for aid in targets:
        cfg = AGENTS[aid]
        cmd = cfg["cmd"].replace("{prompt}", args.task)
        print(f"  {cfg['name']} running...", end=" ", flush=True)
        start = time.time()
        try:
            subprocess.run(cmd, shell=True, capture_output=True, timeout=300)
            elapsed = time.time() - start
            tokens = count_tokens(aid)
            results[aid] = {"name": cfg["name"], "tokens": tokens, "time": elapsed, "error": None}
            print(f"\033[32mOK\033[0m {elapsed:.0f}s")
        except subprocess.TimeoutExpired:
            results[aid] = {"name": cfg["name"], "tokens": {"input":0,"output":0}, "time":0, "error":"timeout"}
            print("\033[31mTIMEOUT\033[0m")
        except Exception as e:
            results[aid] = {"name": cfg["name"], "tokens": {"input":0,"output":0}, "time":0, "error":str(e)}
            print(f"\033[31mERR\033[0m")
        time.sleep(2)

    print("\n  Agent                Input     Output      Cost")
    print("  " + "-" * 55)
    cd = results.get("collar", {}).get("tokens", {})
    ct = cd.get("input",0) + cd.get("output",0)

    for aid in targets:
        r = results.get(aid, {})
        name = r.get("name", aid)
        tok = r.get("tokens", {})
        inp, out = tok.get("input",0), tok.get("output",0)
        c = cost(inp, out, args.model)
        color = AGENTS.get(aid,{}).get("color","")
        if r.get("error"):
            print(f"  {color}{name:<20s}  {'ERROR':>8s}  {'':>8s}  {'':>7s}\033[0m")
        elif inp == 0:
            print(f"  {color}{name:<20s}  {'N/A':>8s}  {'N/A':>8s}  {'N/A':>7s}\033[0m")
        else:
            print(f"  {color}{name:<20s}  {fmt(inp):>8s}  {fmt(out):>8s}  ${c:>6.4f}\033[0m")
    print()

    if ct > 0:
        for aid in targets[1:]:
            r = results.get(aid, {})
            tt = r.get("tokens", {}).get("input",0) + r.get("tokens", {}).get("output",0)
            if tt > 0:
                saved = tt - ct
                pct = (saved/tt)*100
                if saved > 0:
                    print(f"  \033[1;32mCollar saved {fmt(saved)} tokens ({pct:.0f}%) vs {r['name']}\033[0m")
                    print(f"    \033[1;32m${cost(cd.get('input',0),cd.get('output',0),args.model) - cost(r['tokens'].get('input',0),r['tokens'].get('output',0),args.model):.4f}\033[0m saved\n")

    if args.json:
        out = {"model": args.model, "results": {}}
        for aid in targets:
            r = results.get(aid, {})
            t = r.get("tokens", {})
            out["results"][aid] = {"agent": r["name"], "input": t["input"], "output": t["output"], "total": t["input"]+t["output"], "time": r["time"], "cost": cost(t["input"],t["output"],args.model)}
        print(json.dumps(out, indent=2))

    if args.dag:
        lines = ["[dogbench-results]"]
        for aid in targets:
            r = results.get(aid, {})
            t = r.get("tokens", {})
            lines.append(f"{aid}-> tokens:{t['input']+t['output']}(11), cost:{cost(t['input'],t['output'],args.model):.5f}(11)")
        Path("results.dag").write_text("\n".join(lines))
        print("  results.dag written\n")

if __name__ == "__main__":
    main()
