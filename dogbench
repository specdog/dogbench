#!/usr/bin/env python3
"""dogbench — collar vs hermes, with and without DAG."""
import argparse, datetime, json, os, subprocess, sys, time
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
TMPDIR = Path("/tmp")
DEFAULT_TASK = (
    "In the specdog/dogbench project: what agents does dogbench support, "
    "what is the benchmark flow, and what does it measure? "
    "Answer concisely from the project structure."
)

AGENTS = {
    "collar_dag":   ("collar + DAG",     'collar chat -q "{prompt}"',   SCRIPT_DIR),
    "collar_nodag": ("collar (no DAG)",  'collar chat -q "{prompt}"',   TMPDIR),
    "hermes_dag":   ("hermes + specs",   'hermes chat -q "{prompt}"',   SCRIPT_DIR),
    "hermes_nodag": ("hermes (no DAG)",  'hermes chat -q "{prompt}"',   TMPDIR),
}

COLORS = ["\033[32m", "\033[33m", "\033[35m", "\033[36m"]

RATES = {
    "deepseek-v4-pro": {"input": 0.50, "output": 2.00},
    "gpt-5":           {"input": 1.25, "output": 10.0},
    "claude-sonnet-4": {"input": 3.00, "output": 15.0},
    "default":         {"input": 1.00, "output":  5.0},
}

def detect_model():
    cfg = Path.home() / ".dag" / "config.yaml"
    if cfg.exists():
        try:
            import yaml
            with open(cfg) as f: d = yaml.safe_load(f) or {}
            m = d.get("model", {})
            if isinstance(m, dict): return m.get("default", "deepseek-v4-pro")
            if isinstance(m, str) and m: return m
        except: pass
    return "deepseek-v4-pro"

def estimate_tokens(text): return max(1, len(text) // 4)
def fmt(n): return f"{n:,}" if n else "N/A"
def cost(i, o, m="default"):
    r = RATES.get(m, RATES["default"])
    return (i/1e6)*r["input"] + (o/1e6)*r["output"]

def db_path(agent_id):
    home = Path.home()
    if agent_id.startswith("collar"): return home / ".dag" / "state.db"
    if agent_id.startswith("hermes"): return home / ".hermes" / "state.db"
    return None

def read_tokens(agent_id, session_id=None):
    db = db_path(agent_id)
    if not db or not db.exists(): return {"input": 0, "output": 0}
    import sqlite3
    for _ in range(60):
        try:
            conn = sqlite3.connect(str(db))
            if session_id:
                rows = conn.execute("SELECT input_tokens, output_tokens FROM sessions WHERE id=?", (session_id,)).fetchall()
            else:
                rows = conn.execute("SELECT input_tokens, output_tokens FROM sessions ORDER BY started_at DESC LIMIT 1").fetchall()
            conn.close()
            if rows and (rows[0][0] or 0) > 0:
                return {"input": rows[0][0], "output": rows[0][1] or 0}
        except: pass
        time.sleep(1)
    return {"input": 0, "output": 0}

def main():
    p = argparse.ArgumentParser()
    p.add_argument("task", nargs="?", default=DEFAULT_TASK)
    p.add_argument("--model", default=detect_model())
    p.add_argument("--submit", action="store_true")
    p.add_argument("--no-submit", action="store_true")
    args = p.parse_args()
    do_submit = not args.no_submit

    for exe in ["collar", "hermes"]:
        if subprocess.run(["which", exe], capture_output=True).returncode != 0:
            print(f"{exe} not installed"); sys.exit(1)

    task_tokens = estimate_tokens(args.task)
    ts = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    print(f"\n\033[1m  dogbench\033[0m  4 agents  model={args.model}  task={task_tokens}t\n")

    results = {}
    for i, (aid, (name, cmd_tpl, cwd)) in enumerate(AGENTS.items()):
        cmd = cmd_tpl.replace("{prompt}", args.task)
        print(f"  {COLORS[i]}{name}...\033[0m", end=" ", flush=True)
        start = time.time()
        try:
            proc = subprocess.run(cmd, shell=True, capture_output=True, timeout=300, cwd=str(cwd))
            elapsed = time.time() - start
            sid = None
            for line in (proc.stderr + proc.stdout).decode(errors="replace").splitlines():
                if "Session:" in line:
                    sid = line.split("Session:")[-1].strip().split()[0]
                    break
            tokens = read_tokens(aid, session_id=sid)
            ok = tokens["input"] > 0
            results[aid] = {"name": name, "tokens": tokens, "time": elapsed, "ok": ok, "_sid": sid}
            print(f"\033[32m{fmt(tokens['input'])}t\033[0m {elapsed:.0f}s" if ok else f"\033[33m?t\033[0m {elapsed:.0f}s")
        except subprocess.TimeoutExpired:
            results[aid] = {"name": name, "tokens": {"input":0,"output":0}, "time": 0, "ok": False, "_sid": None}
            print("\033[31mTIMEOUT\033[0m")
        except Exception as e:
            results[aid] = {"name": name, "tokens": {"input":0,"output":0}, "time": 0, "ok": False, "_sid": None}
            print(f"\033[31mERR {e}\033[0m")
        time.sleep(3)

    for aid in AGENTS:
        r = results.get(aid, {})
        if not r.get("ok") and r.get("_sid"):
            tokens = read_tokens(aid, session_id=r["_sid"])
            if tokens["input"] > 0:
                results[aid]["tokens"] = tokens; results[aid]["ok"] = True
                print(f"  \033[33mrecovered {aid} {tokens['input']:,}t\033[0m")

    print("\n  Agent                  Input     Output      Cost  Overhead")
    print("  " + "-" * 66)
    cd = results.get("collar_dag", {}).get("tokens", {})
    ct = cd.get("input", 0) + cd.get("output", 0)

    for i, aid in enumerate(AGENTS):
        r = results.get(aid, {})
        tok = r.get("tokens", {})
        inp, out = tok.get("input", 0), tok.get("output", 0)
        c = cost(inp, out, args.model)
        oh = f"{inp//task_tokens}x" if task_tokens and inp else "-"
        if inp == 0:
            print(f"  {COLORS[i]}{r['name']:<22s}  {'N/A':>8s}  {'N/A':>8s}  {'N/A':>7s}  {'N/A':>7s}\033[0m")
        else:
            print(f"  {COLORS[i]}{r['name']:<22s}  {fmt(inp):>8s}  {fmt(out):>8s}  ${c:>6.4f}  {oh:>8s}\033[0m")
    print()

    if ct > 0:
        for aid in AGENTS:
            if aid == "collar_dag": continue
            r = results.get(aid, {})
            tt = r.get("tokens", {}).get("input", 0) + r.get("tokens", {}).get("output", 0)
            if tt > 0:
                saved = tt - ct
                pct = abs(saved) / max(ct, tt) * 100
                if saved > 0:
                    print(f"  \033[1;32mcollar+DAG saved {fmt(saved)}t ({pct:.0f}%) vs {r['name']}\033[0m")
                elif saved < 0:
                    print(f"  \033[1;31mcollar+DAG used {fmt(-saved)}t more ({pct:.0f}%) vs {r['name']}\033[0m")
        print()

    agents_out = []; collar_total = 0
    for aid in AGENTS:
        r = results.get(aid, {})
        t = r.get("tokens", {})
        total = t["input"] + t["output"]
        agents_out.append({"id": aid, "name": r["name"], "input": t["input"], "output": t["output"],
            "total": total, "time": round(r.get("time", 0), 1),
            "cost": round(cost(t["input"], t["output"], args.model), 6)})
        if aid == "collar_dag": collar_total = total

    run = {"timestamp": ts, "model": args.model, "task_tokens": task_tokens,
           "agents": agents_out, "collar_dag_total": collar_total}

    hist_path = SCRIPT_DIR / "results.json"
    history = []
    if hist_path.exists():
        try:
            history = json.loads(hist_path.read_text())
            if not isinstance(history, list): history = [history]
        except: pass
    history.append(run)
    if len(history) > 20: history = history[-20:]
    hist_path.write_text(json.dumps(history, indent=2))
    print(json.dumps(run, indent=2))

    if do_submit:
        branch = f"results/auto-{datetime.datetime.now().strftime('%Y%m%d-%H%M%S')}"
        subprocess.run(["git", "checkout", "-b", branch], cwd=SCRIPT_DIR, capture_output=True)
        subprocess.run(["git", "add", "results.json"], cwd=SCRIPT_DIR, capture_output=True)
        subprocess.run(["git", "commit", "-m", f"chore: auto-submit {ts}"], cwd=SCRIPT_DIR, capture_output=True)
        r = subprocess.run(["git", "push", "origin", branch], cwd=SCRIPT_DIR, capture_output=True, text=True)
        if r.returncode == 0:
            pr = subprocess.run(["gh", "pr", "create", "--repo", "specdog/dogbench", "--head", branch,
                  "--base", "main", "--title", f"chore: auto-submit {ts}",
                  "--body", f"```json\n{json.dumps(run, indent=2)}\n```"],
                  cwd=SCRIPT_DIR, capture_output=True, text=True)
            print(f"\n  \033[32m{pr.stdout.strip()}\033[0m")
        else:
            print(f"\n  \033[33mpush failed\033[0m")

if __name__ == "__main__":
    main()
