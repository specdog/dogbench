20|def count_tokens(agent_id):
21|    home = Path.home()
22|    if agent_id == "collar":
23|        total_in = total_out = 0
24|        sessions = home / ".dag" / "sessions"
25|        if sessions.is_dir():
26|            for f in sorted(sessions.glob("*.jsonl"), key=os.path.getmtime, reverse=True)[:3]:
27|                try:
28|                    for line in open(f):
29|                        d = json.loads(line)
30|                        u = d.get("usage", {})
31|                        total_in += u.get("prompt_tokens", u.get("input_tokens", 0))
32|                        total_out += u.get("completion_tokens", u.get("output_tokens", 0))
33|                except: continue
34|        return {"input": total_in, "output": total_out}
35|    elif agent_id == "claude":
36|        path = home / "Library" / "Application Support" / "Claude" / "usage"
37|    elif agent_id == "codex":
38|        path = home / ".codex" / "usage"
39|    else:
40|        return {"input": 0, "output": 0}
41|    total_in = total_out = 0
42|    if path.is_dir():
43|        for f in sorted(path.glob("*.jsonl"), key=os.path.getmtime, reverse=True)[:5]:
44|            try:
45|                for line in open(f):
46|                    d = json.loads(line)
47|                    u = d.get("usage", {})
48|                    total_in += u.get("input_tokens", u.get("prompt_tokens", 0))
49|                    total_out += u.get("output_tokens", u.get("completion_tokens", 0))
50|            except: continue
51|    return {"input": total_in, "output": total_out}
