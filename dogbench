#!/usr/bin/env python3
"""dogbench v2 — deterministic test suite with ground truth verification."""
import argparse, datetime, json, os, shlex, re, statistics, subprocess, sys, time
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
TMPDIR = Path("/tmp")
RUNS = 3

# ── Test suite ── each test has a task, ground truth keywords, and a verifier
TESTS = [
    {
        "id": "agents",
        "task": "What agents does dogbench support? List their names exactly as defined in the project.",
        "verify": lambda answer: all(k in answer.lower() for k in ["collar", "hermes", "claude", "codex"]),
        "ground": "collar, hermes, claude, codex"
    },
    {
        "id": "flow",
        "task": "What is the benchmark flow in dogbench? List the steps in order.",
        "verify": lambda answer: all(k in answer.lower() for k in ["detect", "run", "collect", "compare", "output"]),
        "ground": "Detect→Run→Collect→Compare→Output"
    },
    {
        "id": "measures",
        "task": "What does dogbench measure? List the metrics.",
        "verify": lambda answer: all(k in answer.lower() for k in ["input", "output", "token", "cost"]),
        "ground": "input tokens, output tokens, cost (USD)"
    },
    {
        "id": "ci",
        "task": "How does the CI workflow validate benchmark submissions? What does it check?",
        "verify": lambda answer: any(k in answer.lower() for k in ["json", "validate", "schema", "assert"]),
        "ground": "CI validates results.json schema with assertions"
    },
]

AGENTS = {
    "hermes":      ("hermes",              'hermes chat -q {task}',   TMPDIR),
    "hermes_dag":  ("hermes + dotdog",     'hermes chat -q {task}',   SCRIPT_DIR),
    "collar":      ("collar",              'collar chat -q {task}',   TMPDIR),
    "collar_dag":  ("collar + dotdog",     'collar chat -q {task}',   SCRIPT_DIR),
}

COLORS = {"hermes": "\033[36m", "hermes_dag": "\033[35m", "collar": "\033[33m", "collar_dag": "\033[32m"}

RATES = {"deepseek-v4-pro": {"input": 0.50, "output": 2.00}, "default": {"input": 1.00, "output": 5.00}}

def detect_model():
    cfg = Path.home() / ".dag" / "config.yaml"
    if cfg.exists():
        try:
            import yaml
            with open(cfg) as f: d = yaml.safe_load(f) or {}
            m = d.get("model", {})
            if isinstance(m, dict): return m.get("default", "deepseek-v4-pro")
            if isinstance(m, str) and m: return m
        except: pass
    return "deepseek-v4-pro"

def fmt(n): return f"{n:,}" if n else "N/A"
def cost(i, o, m="default"):
    r = RATES.get(m, RATES["default"])
    return (i/1e6)*r["input"] + (o/1e6)*r["output"]
def db_path(aid):
    home = Path.home()
    if aid.startswith("collar"): return home / ".dag" / "state.db"
    if aid.startswith("hermes"): return home / ".hermes" / "state.db"

def read_tokens(aid, sid=None):
    db = db_path(aid)
    if not db or not db.exists(): return (0, 0)
    import sqlite3
    for _ in range(60):
        try:
            conn = sqlite3.connect(str(db))
            if sid: rows = conn.execute("SELECT input_tokens, output_tokens FROM sessions WHERE id=?", (sid,)).fetchall()
            else: rows = conn.execute("SELECT input_tokens, output_tokens FROM sessions ORDER BY started_at DESC LIMIT 1").fetchall()
            conn.close()
            if rows and (rows[0][0] or 0) > 0: return (rows[0][0], rows[0][1] or 0)
        except: pass
        time.sleep(1)
    return (0, 0)

def get_answer(aid, sid):
    """Extract the assistant's final answer from the session."""
    db = db_path(aid)
    if not db or not db.exists(): return ""
    import sqlite3
    conn = sqlite3.connect(str(db))
    msgs = conn.execute("SELECT role, content FROM messages WHERE session_id=? AND role='assistant' ORDER BY id DESC LIMIT 1", (sid,)).fetchall()
    conn.close()
    return msgs[0][1] if msgs else ""

def run_test(aid, name, cmd_tpl, cwd, test):
    """Run one test, return (input_tokens, output_tokens, passed, answer)."""
    task = test["task"]
    cmd = cmd_tpl.replace("{task}", shlex.quote(task))
    start = time.time()
    try:
        proc = subprocess.run(cmd, shell=True, capture_output=True, timeout=300, cwd=str(cwd))
        elapsed = time.time() - start
        sid = None
        for line in (proc.stderr + proc.stdout).decode(errors="replace").splitlines():
            if "Session:" in line:
                sid = line.split("Session:")[-1].strip().split()[0]
                break
        inp, out = read_tokens(aid, sid)
        answer = get_answer(aid, sid) if sid else ""
        passed = test["verify"](answer) if answer else False
        return (inp, out, passed, elapsed, answer[:200] if answer else "")
    except Exception as e:
        return (0, 0, False, 0, str(e)[:100])

def main():
    p = argparse.ArgumentParser()
    p.add_argument("--model", default=detect_model())
    p.add_argument("--runs", type=int, default=RUNS)
    p.add_argument("--submit", action="store_true")
    args = p.parse_args()

    for exe in ["collar", "hermes"]:
        if subprocess.run(["which", exe], capture_output=True).returncode != 0:
            print(f"{exe} not installed"); sys.exit(1)

    total = len(AGENTS) * len(TESTS) * args.runs
    print(f"\n\033[1m  dogbench v2\033[0m  {len(AGENTS)} agents × {len(TESTS)} tests × {args.runs} runs = {total} total\n")

    # ── Run all tests ──
    all_results = {}
    for aid, (name, cmd_tpl, cwd) in AGENTS.items():
        print(f"  \033[1m{COLORS.get(aid,'')}{name}\033[0m")
        agent_data = {}
        for test in TESTS:
            tid = test["id"]
            runs = []
            for rn in range(1, args.runs + 1):
                inp, out, passed, elapsed, answer = run_test(aid, name, cmd_tpl, cwd, test)
                runs.append((inp, out, passed, elapsed))
                status = "\033[32m✓\033[0m" if passed else "\033[31m✗\033[0m"
                print(f"    {tid} run {rn}/{args.runs}  {status} {fmt(inp)}t/{fmt(out)}t {elapsed:.0f}s")
                time.sleep(2)
            agent_data[tid] = runs
        all_results[aid] = agent_data
        print()

    # ── Summary ──
    print(f"  {'Agent':<20s} {'Test':<10s} {'Pass':>5s} {'Min In':>10s} {'Avg Total':>10s} {'Cost':>8s}")
    print("  " + "-" * 70)

    summary = {}
    for aid, (name, _, _) in AGENTS.items():
        agent_total = 0
        agent_passed = 0
        agent_tests = 0
        for tid in TESTS:
            tid_short = tid["id"]
            runs = all_results[aid][tid_short]
            passed_runs = [r for r in runs if r[2]]
            all_total = [r[0]+r[1] for r in passed_runs] if passed_runs else [r[0]+r[1] for r in runs if r[0] > 0]
            if all_total:
                min_in = min(r[0] for r in runs if r[0] > 0)
                avg_total = statistics.mean(all_total)
                avg_cost = cost(statistics.mean([r[0] for r in runs if r[0] > 0]), statistics.mean([r[1] for r in runs if r[0] > 0]), args.model)
                agent_total += avg_total
            else:
                min_in = 0; avg_total = 0; avg_cost = 0

            pass_rate = len(passed_runs)
            agent_passed += pass_rate
            agent_tests += args.runs

            color = COLORS.get(aid, "")
            print(f"  {color}{name:<20s} {tid_short:<10s} {pass_rate:>4d}/{args.runs:<3d} {fmt(int(min_in)):>10s} {fmt(int(avg_total)):>10s} ${avg_cost:>7.4f}\033[0m")

        summary[aid] = {"name": name, "passed": agent_passed, "tests": agent_tests, "avg_total": round(agent_total / len(TESTS)) if agent_total else 0}

    print()
    print(f"  {'Agent':<20s} {'Pass Rate':>10s} {'Avg Tokens':>12s}")
    print("  " + "-" * 45)
    for aid, (name, _, _) in AGENTS.items():
        s = summary[aid]
        rate = f"{s['passed']}/{s['tests']}" if s['tests'] else "N/A"
        pct = f" ({round(s['passed']/s['tests']*100)}%)" if s['tests'] else ""
        print(f"  {COLORS.get(aid,'')}{name:<20s} {rate:>10s}{pct:<7s} {fmt(s['avg_total']):>12s}\033[0m")

    # JSON
    ts = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    run_data = {"timestamp": ts, "model": args.model, "runs_per_test": args.runs,
                "tests": [t["id"] for t in TESTS],
                "results": {}}
    for aid, name, _, _ in [(a, n, _, _) for a, (n, _, _) in AGENTS.items()]:
        s = summary[aid]
        run_data["results"][aid] = {"name": name, "passed": s["passed"], "tests": s["tests"], "avg_tokens": s["avg_total"]}
    print(json.dumps(run_data, indent=2))

    # Save
    hist_path = SCRIPT_DIR / "results.json"
    history = []
    if hist_path.exists():
        try:
            history = json.loads(hist_path.read_text())
            if not isinstance(history, list): history = [history]
        except: pass
    history.append(run_data)
    if len(history) > 20: history = history[-20:]
    hist_path.write_text(json.dumps(history, indent=2))

if __name__ == "__main__":
    main()
